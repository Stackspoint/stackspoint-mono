# Backend Development Dockerfile
FROM node:20-alpine

# Install pnpm
RUN corepack enable && corepack prepare pnpm@10.30.1 --activate

WORKDIR /app

# Copy package files
COPY apps/backend/package.json apps/backend/pnpm-lock.yaml ./

# Install dependencies
RUN pnpm install

# Copy source code
COPY apps/backend ./

EXPOSE 3000

CMD ["pnpm", "start:dev"]
